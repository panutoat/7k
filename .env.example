# PostgreSQL connection string used by the API routes.
# If unset, the app falls back to an embedded PGlite database (local dev only).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/7k_combo

# Set to "true" if your Postgres requires SSL (e.g. Neon, Supabase, Railway).
PGSSL=false

# --- Auth (guild war) ------------------------------------------------------
# Admin password (full management access).
ADMIN_PASSWORD=admin1234
# Shared guild password — members log in with their name + this password.
MEMBER_PASSWORD=guild1234
# Secret used to sign the session cookie. Use a long random string in prod.
AUTH_SECRET=change-me-to-a-long-random-string
